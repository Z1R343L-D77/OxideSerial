{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OxideSerial",
  "version": "0.3.0",
  "identifier": "com.z1r343l.oxide-serial",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:14201",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OxideSerial",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}